{
  "title": "Color Rules example",
  "uid": "colorrules-example",
  "editable": true,
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Example — same node, rx solid / tx dashed",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-testdata-datasource", "uid": "-- Grafana --" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "colorrules" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-testdata-datasource", "uid": "-- Grafana --" },
          "scenarioId": "random_walk",
          "alias": "node1 rx"
        },
        {
          "refId": "B",
          "datasource": { "type": "grafana-testdata-datasource", "uid": "-- Grafana --" },
          "scenarioId": "random_walk",
          "alias": "node1 tx"
        },
        {
          "refId": "C",
          "datasource": { "type": "grafana-testdata-datasource", "uid": "-- Grafana --" },
          "scenarioId": "random_walk",
          "alias": "node2 rx"
        },
        {
          "refId": "D",
          "datasource": { "type": "grafana-testdata-datasource", "uid": "-- Grafana --" },
          "scenarioId": "random_walk",
          "alias": "node2 tx"
        }
      ],
      "transformations": [
        {
          "id": "color-rules",
          "options": {
            "colorRules": [
              {
                "id": "example",
                "namePattern": "^(?<node>\\S+) (rx|tx)$",
                "colorGroup": "node",
                "lineStyles": [
                  {
                    "id": "tx-dash",
                    "captureGroup": "2",
                    "matchValue": "tx",
                    "style": "dash",
                    "dash": [6, 3],
                    "opacity": 0
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "5s"
}
